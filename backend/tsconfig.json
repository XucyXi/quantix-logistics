{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "NodeNext", // Päivitetty: NodeNext (piti täsmätä resoluutioon)
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "docs"]
}
