# Tämä testi triggeröi nyt bäkkärillä geokoodauksen delivery_address-kentän perusteella.
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "delivery_address": "Keimolankaarre 10",
    "notes": "Soita ovikelloa, summeri on rikki.",
    "scheduled_delivery": "2026-04-29 18:00:00",
    "items": [
        {
            "product_id": 1,
            "quantity": 2
        }
    ]
}

