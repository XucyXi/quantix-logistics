# ==========================================
# TIETOKANNAN ASETUKSET (Sovelluksen käyttö)
# ==========================================
# Palvelimen osoite (paikallisessa kehityksessä yleensä localhost)
DB_HOST=localhost

# Tietokannan nimi, johon sovellus yhdistää
DB_NAME=qlogistics_db

# Sovelluksen käyttämä tietokantakäyttäjä ja salasana
DB_USER=logistics_app
DB_PASS=syota_tahan_salasana

# ==========================================
# TIETOKANNAN ASETUKSET (Alustus/Setup)
# ==========================================
# Näitä tunnuksia käytetään vain kerran, kun ajat 'npm run db:init'.
# Tällä käyttäjällä (esim. root) pitää olla oikeus luoda uusia tietokantoja ja käyttäjiä.
DB_ADMIN_USER=root
DB_ADMIN_PASS=syota_tahan_root_salasana

# ==========================================
# PALVELIMEN ASETUKSET
# ==========================================
# Portti, jossa Express-backend pyörii
PORT=3000

# CORS: Sallitut osoitteet, joista backend ottaa pyyntöjä vastaan (erota pilkulla)
# Lokaalissa kehityksessä Viten oletusosoitteet riittävät.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# TURVALLISUUS (Authentication)
# ==========================================
# Salaisuus, jolla JWT (JSON Web Token) -istunnot allekirjoitetaan.
# Keksi tähän jokin pitkä ja satunnainen merkkijono (esim. "super_salainen_avain_12345!").
JWT_SECRET=syota_tahan_pitka_satunnainen_merkkijono